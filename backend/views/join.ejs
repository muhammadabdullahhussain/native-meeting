<div
  class="container mx-auto px-4 py-20 flex flex-col items-center justify-center min-h-[80vh] text-center"
>
  <!-- Profile Card -->
  <div
    class="glass-card p-10 rounded-3xl max-w-md w-full relative overflow-hidden"
  >
    <!-- Glow Effect -->
    <div
      class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-primary/20 to-transparent pointer-events-none"
    ></div>

    <div class="relative z-10">
      <img
        src="<%= inviterAvatar %>"
        alt="<%= inviterName %>"
        class="w-24 h-24 rounded-full border-4 border-primary mx-auto mb-6 shadow-2xl shadow-primary/50 object-cover"
      />

      <h1 class="text-3xl font-bold mb-4">
        <span class="text-primary"><%= inviterName %></span> invited you!
      </h1>

      <p class="text-gray-300 mb-8 leading-relaxed">
        Join Interesta to connect with people who share your passions. Use this
        code during signup to unlock a
        <span class="text-white font-bold bg-white/10 px-2 py-1 rounded"
          >Free Group Pass</span
        >.
      </p>

      <!-- Code Box -->
      <div
        class="bg-black/40 border border-white/10 rounded-xl p-6 mb-8 backdrop-blur-sm"
      >
        <div
          class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3"
        >
          Your Referral Code
        </div>
        <div
          class="text-4xl font-mono font-bold text-white tracking-widest select-all"
          id="refCode"
        >
          <%= code %>
        </div>
      </div>

      <button
        onclick="copyCode()"
        class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-xl transition-all transform active:scale-95 shadow-lg shadow-indigo-500/30 flex items-center justify-center gap-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path d="M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" />
          <path
            d="M6 3a2 2 0 00-2 2v11a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2 3 3 0 01-3 3H9a3 3 0 01-3-3z"
          />
        </svg>
        Copy Code
      </button>
    </div>
  </div>

  <!-- Store Badges -->
  <div class="mt-12 flex gap-4 opacity-80 hover:opacity-100 transition-opacity">
    <a
      href="#"
      class="bg-black border border-white/20 rounded-lg px-6 py-3 flex items-center gap-3 hover:border-white/50 transition"
    >
      <span class="text-2xl"></span>
      <div class="text-left leading-tight">
        <div class="text-[10px] uppercase font-bold">Download on the</div>
        <div class="text-lg font-bold">App Store</div>
      </div>
    </a>
    <a
      href="#"
      class="bg-black border border-white/20 rounded-lg px-6 py-3 flex items-center gap-3 hover:border-white/50 transition"
    >
      <span class="text-2xl">▶</span>
      <div class="text-left leading-tight">
        <div class="text-[10px] uppercase font-bold">Get it on</div>
        <div class="text-lg font-bold">Google Play</div>
      </div>
    </a>
  </div>

  <!-- Success Toast -->
  <div
    id="toast"
    class="fixed bottom-10 left-1/2 transform -translate-x-1/2 bg-green-500 text-white px-6 py-3 rounded-full font-bold shadow-2xl translate-y-20 opacity-0 transition-all duration-300 pointer-events-none"
  >
    Code Copied! 🚀
  </div>

  <script>
    function copyCode() {
      const code = document.getElementById("refCode").innerText;
      navigator.clipboard.writeText(code).then(() => {
        const toast = document.getElementById("toast");
        toast.classList.remove("translate-y-20", "opacity-0");
        setTimeout(() => {
          toast.classList.add("translate-y-20", "opacity-0");
        }, 2000);
      });
    }
  </script>
</div>
