<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' ? title : 'Interesta' %></title>

    <!-- Favicon -->
    <link
      rel="icon"
      href="https://cdn-icons-png.flaticon.com/512/3757/3757997.png"
      type="image/png"
    />

    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: "#6366F1",
              "primary-dark": "#4F46E5",
              bg: "#0F172A",
              card: "rgba(255, 255, 255, 0.05)",
            },
            fontFamily: {
              sans: ["Inter", "sans-serif"],
            },
          },
        },
      };
    </script>

    <style>
      body {
        background-color: #0f172a;
        color: white;
        font-family: "Inter", sans-serif;
      }
      .glass-nav {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
      }
      .text-gradient {
        background: linear-gradient(to right, #818cf8, #c084fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .glow-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: radial-gradient(
          circle at 50% 0%,
          rgba(99, 102, 241, 0.15),
          transparent 60%
        );
        z-index: -1;
        pointer-events: none;
      }
    </style>
  </head>
  <body class="flex flex-col min-h-screen">
    <div class="glow-bg"></div>

    <!-- Navbar -->
    <nav class="glass-nav fixed w-full z-50 top-0">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center">
            <a href="/" class="text-2xl font-bold text-white tracking-tight"
              >Interesta<span class="text-primary">.</span></a
            >
          </div>
          <div class="hidden md:block">
            <div class="ml-10 flex items-baseline space-x-4">
              <a
                href="/"
                class="hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-colors"
                >Home</a
              >
              <a
                href="/about"
                class="hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-colors"
                >About</a
              >
              <a
                href="/pricing"
                class="hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-colors"
                >Pricing</a
              >
              <a
                href="/safety"
                class="hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-colors"
                >Safety</a
              >
              <a
                href="/help"
                class="hover:bg-white/10 px-3 py-2 rounded-md text-sm font-medium transition-colors"
                >Help</a
              >
            </div>
          </div>
          <div>
            <a
              href="/join"
              class="bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-full text-sm font-bold transition-all shadow-lg shadow-indigo-500/30"
            >
              Get App
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow pt-20"><%- body %></main>

    <!-- Footer -->
    <footer class="border-t border-white/10 bg-slate-900/50 mt-20">
      <div class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <h3
              class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4"
            >
              Company
            </h3>
            <ul class="space-y-3">
              <li>
                <a
                  href="/about"
                  class="text-gray-300 hover:text-white transition"
                  >About Us</a
                >
              </li>
              <li>
                <a
                  href="/pricing"
                  class="text-gray-300 hover:text-white transition"
                  >Pricing</a
                >
              </li>
              <li>
                <a href="#" class="text-gray-300 hover:text-white transition"
                  >Careers</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h3
              class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4"
            >
              Support
            </h3>
            <ul class="space-y-3">
              <li>
                <a
                  href="/help"
                  class="text-gray-300 hover:text-white transition"
                  >Help Center</a
                >
              </li>
              <li>
                <a
                  href="/safety"
                  class="text-gray-300 hover:text-white transition"
                  >Safety Center</a
                >
              </li>
              <li>
                <a
                  href="/legal"
                  class="text-gray-300 hover:text-white transition"
                  >Community Guidelines</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h3
              class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4"
            >
              Legal
            </h3>
            <ul class="space-y-3">
              <li>
                <a
                  href="/legal"
                  class="text-gray-300 hover:text-white transition"
                  >Privacy Policy</a
                >
              </li>
              <li>
                <a
                  href="/legal"
                  class="text-gray-300 hover:text-white transition"
                  >Terms of Service</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h3
              class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4"
            >
              Download
            </h3>
            <div class="flex flex-col gap-3">
              <a
                href="#"
                class="flex items-center gap-2 bg-white/5 hover:bg-white/10 px-4 py-2 rounded-lg border border-white/10 transition"
              >
                <span class="text-xl"></span>
                <span class="text-sm">App Store</span>
              </a>
              <a
                href="#"
                class="flex items-center gap-2 bg-white/5 hover:bg-white/10 px-4 py-2 rounded-lg border border-white/10 transition"
              >
                <span class="text-xl">▶</span>
                <span class="text-sm">Google Play</span>
              </a>
            </div>
          </div>
        </div>
        <div
          class="mt-12 pt-8 border-t border-white/10 text-center text-gray-500 text-sm"
        >
          &copy; <%= new Date().getFullYear() %> Interesta Inc. All rights
          reserved.
        </div>
      </div>
    </footer>
  </body>
</html>
