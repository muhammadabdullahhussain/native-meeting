{
    "cli": {
        "version": ">= 14.1.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://bondus-backend.onrender.com/api",
                "EXPO_PUBLIC_SOCKET_URL": "https://bondus-backend.onrender.com"
            }
        },
        "production": {
            "autoIncrement": true
        }
    },
    "submit": {
        "production": {}
    }
}